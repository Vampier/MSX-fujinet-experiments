100 CLEAR 768
110 SCREEN0,0,0:WIDTH80:COLOR15,0,0
120 VDP(13)=&HA4:VDP(14)=&H10
130 FORI=&H800TO&H809:VPOKEI,&HFF:NEXT
140 FORI=&H80ATO&H8EF:VPOKEI,&H0:NEXT
150 LOCATE0,0:PRINT"Fujinet Chat Experimental"
160 FORI=&H8C8TO&H8D1:VPOKE I,&HFF:NEXTI
170 POKE &HF3B1,26:'Allow 26 lines
180 _NINIT:N$="N:[localhost]/fujinet_chat.php"
190 E$=STRING$(79," ")
200 GOSUB 330:'getcount first time
210 GOSUB 380:'get text first time
220 ON INTERVAL=300GOSUB 500:'check text count every 5 seconds
230 INTERVAL ON
240 I$=INKEY$
250 IF I$=CHR$(27)THEN POKE &HF3B1,24:END
251 IF I$=CHR$(8) THEN P$=MID$(P$,1,LEN(P$)-1):GOTO240
260 IF I$<>"" THEN P$=P$+I$
270 LOCATE 0,20:PRINT P$+"_  "
280 IF I$=CHR$(13)THENGOSUB560
290 GOTO 240
300 END
310 '
320 ' Get Count
321 IF LEN(P$)>0THEN RETURN
330 U$=N$+"/count.json"
340 _NOPEN(U$,12,0):_NJSONPARSE(U$)
350 _NJSONQUERY(U$,"/lines",F$,S%)
360 C=VAL(F$):RETURN
370 '
380 'Get Text
390 U$=N$+"/?get=20"
400 _NOPEN(U$,12,0):_NJSONPARSE(U$)
410 FORI=19TO1 STEP -1:LOCATE 0,I
420 PRINT E$
430 LOCATE 0,I
440 J$="/messages/"+MID$(STR$(I),2)+"/message"
450 _NJSONQUERY(U$,J$,F$,S%)
460 PRINT "[MSG]"+F$
470 LOCATE 75,20:PRINT S%
480 NEXT I
490 RETURN
500 O=C:LOCATE 60,22:PRINT"checking";:PRINTO;:PRINTC
510 IF LEN(P$)>0THENRETURN
520 GOSUB 320
530 LOCATE 0,22:PRINT E$
540 IF C<>O THEN PLAY"l64s10m2100o5f":GOSUB 380
550 RETURN
560 INTERVAL OFF:GOSUB 660
570 U$=N$+"/?msg="+Q$
571 LOCATE0,20:PRINT E$
580 'PRINT U$
590 CALL NOPEN(U$,12,0):_NJSONPARSE(U$)
600 J$="/message"
610 CALL NJSONQUERY(U$,J$,F$,S%):PLAY"l64s11m900o5c"
620 P$=""
630 LOCATE 0,22:PRINT ">>"+F$,S%
640 INTERVAL ON
650 RETURN
660 ' FULL URL ENCODE SUBROUTINE
670 Q$=""
680 FOR I=1 TO LEN(P$)
690 C=ASC(MID$(P$,I,1))
700 IF C=13 OR C=10 THEN 810
710 IF C=32 THEN Q$=Q$+"%20":GOTO 810
720 IF C>=65 AND C<=90 THEN 800
730 IF C>=97 AND C<=122 THEN 800
740 IF C>=48 AND C<=57 THEN 800
750 IF C=45 OR C=46 OR C=126 THEN 800
760 ' Encode
770 H$=HEX$(C)
780 IF LEN(H$)=1 THEN H$="0"+H$
790 Q$=Q$+"%"+H$
800 Q$=Q$+CHR$(C)
810 NEXT I
820 RETURN
