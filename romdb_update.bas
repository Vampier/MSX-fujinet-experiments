10 SCREEN0,0,0:COLOR3,0,0:WIDTH32:KEYOFF
100 _NINIT
110 U$="N:https://romdb.vampier.net/api/get_latest.php"
120 _NOPEN(U$,12,0)
130 _NJSONPARSE(U$)
140 _NJSONQUERY(U$,"/0/last_modified",F$,S%)
200 GOSUB 240
201 PRINT "ROMDB Was last updated on"
211 PRINT "Time:";MID$(STR$(Y),2);"-";RIGHT$(STR$(100+M),2);"-";RIGHT$(STR$(100+D),2)
221 PRINT "Date:";RIGHT$(STR$(100+H),2);":";RIGHT$(STR$(100+MI),2);":";RIGHT$(STR$(100+S),2)
230 END
240 ' === UNIX TS CONVERT ===
250 TS#=VAL(F$)
260 DS#=INT(TS#/86400#)
270 SS#=TS#-DS#*86400#
300 ' --- TIME ---
310 H=INT(SS#/3600)
320 MI=INT((SS#-H*3600)/60)
330 S=INT(SS#-H*3600-MI*60)
350 ' --- YEAR ---
360 Y=1970
370 LP=0
380 IF (Y MOD 4=0 AND Y MOD 100<>0) OR (Y MOD 400=0) THEN LP=1
390 DY=365+LP
400 IF DS#<DY THEN 460
410 DS#=DS#-DY
420 Y=Y+1
430 GOTO 370
460 ' --- MONTH ---
470 M=1
480 MD=31
490 IF M=2 THEN MD=28+LP
500 IF M=4 OR M=6 OR M=9 OR M=11 THEN MD=30
510 IF DS#<MD THEN 560
520 DS#=DS#-MD
530 M=M+1
540 GOTO 480
560 D=DS#+1
570 RETURN
